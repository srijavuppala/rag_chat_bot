# ===========================
# RAG CHATBOT CONFIGURATION
# ===========================

# === SNOWFLAKE CONFIGURATION ===
# Replace these placeholders with your actual Snowflake credentials
SNOWFLAKE_ACCOUNT=your_account_name.region.provider
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=RAG_CHATBOT_DB
SNOWFLAKE_SCHEMA=PUBLIC

# === MISTRAL LLM CONFIGURATION ===
# Get your API key from: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key

# === APPLICATION CONFIGURATION ===
APP_TITLE=RAG Chatbot
APP_DESCRIPTION=AI-powered document Q&A system

# === DEMO MODE CONFIGURATION ===
# Set to 'false' once you've added real credentials above
DEMO_MODE=false

# === RAG PIPELINE SETTINGS ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_RETRIEVED_DOCS=5
